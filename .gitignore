# =============================================================================
# AgentFlow-Launcher .gitignore
# =============================================================================

# Secrets & environment
.env
*.pem
*.key
credentials.json
secrets.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Outputs & generated files
outputs/
logs/
*.log

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Package managers
node_modules/
Pipfile.lock
poetry.lock

# OS
Desktop.ini
$RECYCLE.BIN/

# Temporary
tmp/
temp/
*.tmp
